{
  "name": "llm-router",
  "version": "1.0.0",
  "description": "OpenAI-compatible LLM router for Cloudflare Workers with provider fallback, key rotation, and an admin UI.",
  "private": true,
  "scripts": {
    "build": "vite build && tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply llm-router --local",
    "db:migrate": "wrangler d1 migrations apply llm-router --remote",
    "lint": "eslint src ui vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "test:integration": "node tests/smoke/gemini-key.mjs",
    "test:smoke:router": "node tests/smoke/router.mjs",
    "test:smoke": "node tests/smoke/run-all.mjs",
    "test": "npm run test:unit && npm run test:integration"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "hono": "^4.12.27",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "wrangler": "^4.107.0"
  }
}
