{
  "name": "llm-router",
  "version": "1.0.0",
  "description": "OpenAI-compatible LLM router for Cloudflare Workers with provider fallback, key rotation, and an admin UI.",
  "private": true,
  "scripts": {
    "build": "vite build && tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply llm-router --local",
    "db:migrate": "wrangler d1 migrations apply llm-router --remote",
    "typecheck": "tsc --noEmit",
    "test:router": "node scripts/test-router.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "hono": "^4.12.27",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wrangler": "^4.107.0"
  }
}
